# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/ai_tutor"
PGDATABASE="ai_tutor"
PGHOST="localhost"
PGPORT="5432"
PGUSER="username"
PGPASSWORD="password"

# Session Security
SESSION_SECRET="your-super-secret-session-key-change-this-in-production"

# OpenAI Configuration
OPENAI_API_KEY="sk-your-openai-api-key-here"
OPENAI_API_KEY_ENV_VAR="sk-fallback-key-if-needed"

# Azure Speech Services (for narration)
AZURE_SPEECH_KEY="your-azure-speech-service-key"
AZURE_SPEECH_REGION="your-azure-region"

# Stripe Configuration
STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key"
STRIPE_SINGLE_PRICE_ID="price_your-single-subject-price-id"
STRIPE_ALL_PRICE_ID="price_your-all-subjects-price-id"

# Frontend Environment Variables (prefix with VITE_)
VITE_STRIPE_PUBLIC_KEY="pk_test_your-stripe-publishable-key"

# Voice Configuration - Younger, friendlier American accent
AZURE_VOICE_NAME="en-US-AriaNeural"

# Energy Level (calm|neutral|upbeat, default upbeat)
ENERGY_LEVEL="upbeat"

# Voice Testing (set to 1 to enable test mode)
VOICE_TEST_MODE="1"

# ASR (Automatic Speech Recognition) thresholds
ASR_MIN_MS="250"
ASR_MIN_CONFIDENCE="0.5"
VAD_SILENCE_MS="300"
MAX_UTTERANCE_MS="8000"
ASR_PROFILE="balanced"

# LLM Resilience Configuration
LLM_MAX_RETRIES="3"
LLM_BACKOFF_MS="1000"
LLM_CIRCUIT_THRESHOLD="5"
LLM_CIRCUIT_TIMEOUT_MS="45000"
TUTOR_MODEL="gpt-4o-mini"

# Debug mode for tutor (set to 1 to enable debug logging)
DEBUG_TUTOR="1"
DEBUG_API_KEY="debug-key-2024"

# TutorMind Configuration
TUTOR_INCLUSIVE_MODE="true"
TUTOR_MAX_SENTENCES="2"
TUTOR_REQUIRE_QUESTION="true"
TUTOR_DEBUG_CORRECTIONS="true"

# Scalability & Performance Configuration
USE_REALTIME="true"
CACHE_TTL_MIN="1440"
CIRCUIT_COOLDOWN_MS="45000"
MAX_CONCURRENT_USERS="1000"
SEMANTIC_CACHE_SIZE="10000"

# Server Configuration
PORT="5000"
NODE_ENV="development"

# Replit Domains (for OAuth callbacks)
REPLIT_DOMAINS="your-replit-domain.replit.dev"

# Development/Production Toggle
# Set to "production" when deploying
NODE_ENV="development"

# ElevenLabs ConvAI (Multi-Agent System - 5 Age-Specific Tutors)
ELEVENLABS_API_KEY="sk_your-elevenlabs-api-key"
ELEVENLABS_AGENT_35="agent_grades-3-5-id"
ELEVENLABS_AGENT_68="agent_grades-6-8-id"
ELEVENLABS_AGENT_912="agent_grades-9-12-id"
ELEVENLABS_AGENT_K2="agent_k-2-id"
ELEVENLABS_AGENT_COLLEGE="agent_college-adult-id"
ELEVENLABS_AGENT_ID="agent_default-id"
USE_CONVAI="true"

# Resend Email Service (for marketing & transactional emails)
RESEND_API_KEY="re_your-resend-api-key"
RESEND_FROM_EMAIL="hello@jiemastery.ai"

# Stripe Webhook (Railway will need this)
STRIPE_WEBHOOK_SECRET="whsec_your-webhook-secret"

# Railway/Production Deployment URLs
# Update these after deploying to Railway
FRONTEND_URL="https://jie-mastery-tutor-production.up.railway.app"
ALLOWED_ORIGINS="https://jie-mastery-tutor-production.up.railway.app"

# Admin Configuration
ADMIN_EMAIL="admin@example.com"

# =============================================================================
# Avatar Pilot (dev-avatar branch only — DO NOT enable on main / production)
# =============================================================================
# Master switch. Off by default — when false the entire avatar layer is dormant
# and the existing orb / emoji avatar renders exactly as before.
# Set BOTH the server-side var AND the matching VITE_* var (Vite only exposes
# VITE_-prefixed vars to the browser bundle).
AVATAR_ENABLED="false"
VITE_AVATAR_ENABLED="false"

# Provider selection. Phase 1 supports 'simli' only.
AVATAR_PROVIDER="simli"

# Simli credentials. Pollis generates an API key from the Simli dashboard and
# uploads each illustrated avatar to receive a faceId.
SIMLI_API_KEY=""
VITE_SIMLI_API_KEY=""

# Per-persona faceIds. Empty string = no avatar yet → that persona renders the
# orb (no error). Pollis fills these in one-by-one as renders are approved.
SIMLI_FACE_ID_K2=""           # Buddy the Learning Bear        (k-2,  ages 5-7)
SIMLI_FACE_ID_35=""           # Max the Knowledge Explorer     (3-5,  ages 8-11)
SIMLI_FACE_ID_68=""           # Doctor Nova                    (6-8,  ages 11-14)
SIMLI_FACE_ID_912=""          # Professor Ace                  (9-12, ages 14-18)
SIMLI_FACE_ID_COLLEGE=""      # Doctor Morgan                  (college, 18+)

VITE_SIMLI_FACE_ID_K2=""
VITE_SIMLI_FACE_ID_35=""
VITE_SIMLI_FACE_ID_68=""
VITE_SIMLI_FACE_ID_912=""
VITE_SIMLI_FACE_ID_COLLEGE=""

# Per-persona enable flags. Master flag must ALSO be true. Lets Pollis ship
# avatars one at a time as renders come in (Section 2.9 of the brief).
AVATAR_ENABLED_K2="false"
AVATAR_ENABLED_35="false"
AVATAR_ENABLED_68="false"
AVATAR_ENABLED_912="false"
AVATAR_ENABLED_COLLEGE="false"

VITE_AVATAR_ENABLED_K2="false"
VITE_AVATAR_ENABLED_35="false"
VITE_AVATAR_ENABLED_68="false"
VITE_AVATAR_ENABLED_912="false"
VITE_AVATAR_ENABLED_COLLEGE="false"
